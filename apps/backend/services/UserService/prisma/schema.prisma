generator client {
  provider = "prisma-client-js"
  output   = "../src/db/generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

model User {
  id              String    @id @map("_id") @db.ObjectId // Same ID from Auth Service
  username        String    @unique
  email           String    @unique
  displayName     String
  bio             String?
  location        String?
  website         String?
  profileImage    String?
  bannerImage     String?
  dateOfBirth     DateTime?
  
  isPrivate       Boolean   @default(false)
  isActive        Boolean   @default(true)
  
  followersCount  Int       @default(0)
  followingCount  Int       @default(0)
  tweetsCount     Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastActiveAt    DateTime  @default(now())
  
  followers       Follow[]  @relation("UserFollowers")
  following       Follow[]  @relation("UserFollowing")
  blockingUsers   Block[]   @relation("BlockingUser")
  blockedByUsers  Block[]   @relation("BlockedUser")
  mutedUsers      Mute[]    @relation("MutingUser")
  mutedByUsers    Mute[]    @relation("MutedUser")
  
  communityMemberships  CommunityMember[]
  ownedCommunities      Community[]       @relation("CommunityOwner")
  
  notifications   Notification[]
  notificationSettings NotificationSettings?
  
  @@map("users")
}

model Follow {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime  @default(now())
  
  followerId      String    @db.ObjectId
  follower        User      @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId     String    @db.ObjectId
  following       User      @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  
  status          FollowStatus @default(ACCEPTED)
  
  @@unique([followerId, followingId])
  @@map("follows")
}

enum FollowStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Block {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime  @default(now())
  
  blockerId       String    @db.ObjectId
  blocker         User      @relation("BlockingUser", fields: [blockerId], references: [id], onDelete: Cascade)
  
  blockedId       String    @db.ObjectId
  blocked         User      @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  
  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Mute {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  
  muterId         String    @db.ObjectId
  muter           User      @relation("MutingUser", fields: [muterId], references: [id], onDelete: Cascade)
  
  mutedId         String    @db.ObjectId
  muted           User      @relation("MutedUser", fields: [mutedId], references: [id], onDelete: Cascade)
  
  @@unique([muterId, mutedId])
  @@map("mutes")
}

model Community {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String    @unique
  displayName     String
  description     String
  rules           String[]
  bannerImage     String?
  profileImage    String?
  
  isPrivate       Boolean   @default(false)
  allowPosts      Boolean   @default(true)
  requireApproval Boolean   @default(false)
  
  memberCount     Int       @default(0)
  postCount       Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  ownerId         String    @db.ObjectId
  owner           User      @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members         CommunityMember[]
  moderators      CommunityModerator[]
  bannedMembers   CommunityBan[]
  
  @@map("communities")
}

model CommunityMember {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  joinedAt        DateTime  @default(now())
  
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  communityId     String    @db.ObjectId
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  
  status          MemberStatus @default(ACTIVE)
  
  @@unique([userId, communityId])
  @@map("community_members")
}

enum MemberStatus {
  PENDING
  ACTIVE
  LEFT
}

model CommunityModerator {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  assignedAt      DateTime  @default(now())
  
  userId          String    @db.ObjectId
  
  communityId     String    @db.ObjectId
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  
  permissions     ModeratorPermission[]
  
  @@unique([userId, communityId])
  @@map("community_moderators")
}

enum ModeratorPermission {
  MANAGE_POSTS
  MANAGE_MEMBERS
  MANAGE_SETTINGS
  BAN_MEMBERS
}

model CommunityBan {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  reason          String
  
  userId          String    @db.ObjectId
  
  communityId     String    @db.ObjectId
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  
  bannedBy        String    @db.ObjectId
  
  @@unique([userId, communityId])
  @@map("community_bans")
}

model Notification {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  type            NotificationType
  title           String
  message         String
  isRead          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  relatedUserId   String?   @db.ObjectId
  relatedEntityId String?
  relatedEntityType String?
  
  metadata        Json?
  
  @@map("notifications")
}

enum NotificationType {
  FOLLOW
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  MENTION
  LIKE
  RETWEET
  REPLY
  COMMUNITY_INVITE
  COMMUNITY_POST
  COMMUNITY_ANNOUNCEMENT
  SYSTEM
}

model NotificationSettings {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  
  userId          String    @unique @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  emailOnFollow   Boolean   @default(true)
  emailOnMention  Boolean   @default(true)
  emailOnLike     Boolean   @default(false)
  emailOnRetweet  Boolean   @default(true)
  emailOnReply    Boolean   @default(true)
  
  pushOnFollow    Boolean   @default(true)
  pushOnMention   Boolean   @default(true)
  pushOnLike      Boolean   @default(false)
  pushOnRetweet   Boolean   @default(true)
  pushOnReply     Boolean   @default(true)
  
  communityUpdates Boolean  @default(true)
  
  updatedAt       DateTime  @updatedAt
  
  @@map("notification_settings")
}

model ProfileView {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  viewedAt        DateTime  @default(now())
  
  profileId       String    @db.ObjectId
  viewerId        String?   @db.ObjectId
  
  @@map("profile_views")
}