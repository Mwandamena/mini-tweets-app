{
  "name": "@mta/user-service",
  "version": "1.0.0",
  "description": "User service for MTA",
  "main": "src/user.ts",
  "scripts": {
    "start": "ts-node src/user.ts",
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist src/user.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest"
  },
  "dependencies": {
    "@mta/common": "workspace:*",
    "@mta/constants": "workspace:*",
    "@mta/events": "workspace:*",
    "@mta/logger": "workspace:*",
    "@mta/redis-client": "workspace:*",
    "@mta/metrics": "workspace:*",
    "@prisma/client": "^6.19.0",
    "axios": "^1.13.1",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.11",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "qr-image": "^3.2.0",
    "qrcode": "^1.5.4",
    "request-ip": "^3.3.0",
    "resend": "^6.4.1",
    "speakeasy": "^2.0.0",
    "twilio": "^5.10.4",
    "winston": "^3.17.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.11",
    "@types/qr-image": "^3.2.9",
    "@types/qrcode": "^1.5.6",
    "@types/request-ip": "^0.0.41",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.5.3",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "author": "Kelvin Mwandamena",
  "license": "MIT"
}
