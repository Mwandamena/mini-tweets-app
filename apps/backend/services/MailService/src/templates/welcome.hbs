<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        line-height: 1.6;
        color: #1f2937;
        background-color: #f3f4f6;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
      }
      .header {
        background: linear-gradient(135deg, #1d9bf0 0%, #0c7abf 100%);
        padding: 40px 20px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 28px;
      }
      .content {
        padding: 40px 30px;
      }
      .content h2 {
        color: #1f2937;
        font-size: 24px;
        margin-bottom: 20px;
      }
      .content p {
        color: #4b5563;
        font-size: 16px;
        margin-bottom: 15px;
      }
      .button {
        display: inline-block;
        padding: 14px 28px;
        background-color: #1d9bf0;
        color: #ffffff;
        text-decoration: none;
        border-radius: 9px;
        font-weight: bold;
        margin: 20px 0;
      }
      .button:hover {
        background-color: #0c7abf;
      }
      .features {
        margin: 30px 0;
      }
      .feature {
        margin-bottom: 20px;
        padding-left: 30px;
        position: relative;
      }
      .feature:before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #1d9bf0;
        font-weight: bold;
        font-size: 20px;
      }
      .footer {
        background-color: #f9fafb;
        padding: 30px;
        text-align: center;
        color: #6b7280;
        font-size: 14px;
      }
      .social-links {
        margin: 20px 0;
      }
      .social-links a {
        color: #1d9bf0;
        text-decoration: none;
        margin: 0 10px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Welcome to Mini Tweets Application!</h1>
      </div>
      <div class="content">
        <h2>Hi {{username}},</h2>
        <p>We're thrilled to have you join our community! Your account has been
          created successfully.</p>

        <a href="{{appUrl}}" class="button">Get Started</a>

        <div class="features">
          <h3>Here's what you can do:</h3>
          <div class="feature">Share your thoughts with the world</div>
          <div class="feature">Follow interesting people and topics</div>
          <div class="feature">Engage with tweets through likes, retweets, and
            replies</div>
          <div class="feature">Send direct messages to connect privately</div>
          <div class="feature">Discover trending topics and conversations</div>
        </div>

        <p>Need help getting started? Check out our
          <a href="{{appUrl}}/help">Help Center</a>
          or reach out to our support team.</p>
      </div>
      <div class="footer">
        <div class="social-links">
          <a href="{{appUrl}}">Home</a>
          <a href="{{appUrl}}/help">Help</a>
          <a href="{{appUrl}}/terms">Terms</a>
          <a href="{{appUrl}}/privacy">Privacy</a>
        </div>
        <p>&copy; {{year}} Mini Tweets Application. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>