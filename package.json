{
  "name": "my-tweets-application",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter='./apps/backend/services/**'",
    "dev:frontend": "turbo run dev --filter='./apps/frontend/**'",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter='./apps/backend/services/**'",
    "build:frontend": "turbo run build --filter='./apps/frontend/**'",
    "build:packages": "turbo run build --filter='./packages/**'",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "compose": "bash scripts/compose.sh",
    "compose:config": "bash scripts/compose.sh config",
    "compose:ps": "bash scripts/compose.sh ps",
    "compose:up": "bash scripts/compose.sh up:all",
    "compose:up:infra": "bash scripts/compose.sh up:infra",
    "compose:up:backend": "bash scripts/compose.sh up:backend",
    "compose:up:obs": "bash scripts/compose.sh up:obs",
    "compose:up:support": "bash scripts/compose.sh up:support",
    "compose:stop": "bash scripts/compose.sh stop",
    "compose:stop:backend": "bash scripts/compose.sh stop:backend",
    "compose:stop:obs": "bash scripts/compose.sh stop:obs",
    "compose:down": "bash scripts/compose.sh down",
    "compose:logs:obs": "bash scripts/compose.sh logs:obs",
    "clean": "turbo run clean && rm -rf dist",
    "nuke": "pnpm --recursive exec -- rm -rf dist node_modules .turbo"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.7.4",
    "typescript": "^5.0.0"
  }
}
